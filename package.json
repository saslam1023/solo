{
  "name": "solostore",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev:router": "pnpm --filter @solostore/router dev",
    "dev:api": "pnpm --filter @solostore/api dev",
    "dev:webhooks": "pnpm --filter @solostore/webhooks dev",
    "deploy:router": "pnpm --filter @solostore/router deploy",
    "deploy:api": "pnpm --filter @solostore/api deploy",
    "deploy:webhooks": "pnpm --filter @solostore/webhooks deploy",
    "deploy:all": "pnpm deploy:router && pnpm deploy:api && pnpm deploy:webhooks",
    "type-check": "pnpm -r type-check",
    "seed:dev": "bash scripts/seed-dev-tenant.sh f71e79c3fcc24c8c8516ddfbc5ed050d"
  },
  "devDependencies": {
    "tsx": "^4.22.4",
    "typescript": "^5.4.5",
    "wrangler": "^4.105.0"
  },
  "packageManager": "pnpm@9.9.0+sha512.60c18acd138bff695d339be6ad13f7e936eea6745660d4cc4a776d5247c540d0edee1a563695c183a66eb917ef88f2b4feb1fc25f32a7adcadc7aaf3438e99c1"
}
