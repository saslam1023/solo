+# Dashboard static assets (HTML/CSS/JS) — served directly by this Worker.
+# Cloudflare checks this directory for a matching file BEFORE running
+# fetch(); run_worker_first ensures our tenant-resolution + status gate
+# in src/index.ts always runs first, so an unauthenticated/inactive
+# tenant can never reach dashboard files directly by path.
+[assets]
+directory = "./public"
+binding = "ASSETS"
+run_worker_first = true
+
 [vars]
 ENVIRONMENT = "development"
 API_WORKER_URL = "http://localhost:8787"
-PAGES_URL = "http://localhost:8785"
-
 
 # Production environment overrides
 [env.production]
